-- Brick | Fade In
local Workspace    = game:GetService("Workspace")
local Players      = game:GetService("Players")
local RunService   = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Player       = Players.LocalPlayer

local existing = Workspace:FindFirstChild("InfiniteBaseplates")
if existing then existing:Destroy() end

local baseplateFolder = Instance.new("Folder")
baseplateFolder.Name = "InfiniteBaseplates"
baseplateFolder.Parent = Workspace

local BASEPLATE_SIZE      = 2000
local BASEPLATE_THICKNESS = 4
local BASEPLATE_COLOR     = Color3.fromRGB(150, 90, 70)
local GRID_RANGE          = 1
local UPDATE_INTERVAL     = 1

local baseplateGrid = {}
local lockedY       = nil
local lastGridX     = nil
local lastGridZ     = nil

local tweenInfo = TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function getInitialY(hrp)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
    raycastParams.FilterDescendantsInstances = {Player.Character, baseplateFolder}
    local result = Workspace:Raycast(hrp.Position, Vector3.new(0, -1000, 0), raycastParams)
    if result then
        return result.Position.Y - (BASEPLATE_THICKNESS / 2) - 0.1
    end
    return hrp.Position.Y - 20
end

local function addBaseplate(gridX, gridZ)
    local key = gridX .. "," .. gridZ
    if baseplateGrid[key] then return end

    local part = Instance.new("Part")
    part.Name         = "Baseplate"
    part.Size         = Vector3.new(BASEPLATE_SIZE, BASEPLATE_THICKNESS, BASEPLATE_SIZE)
    part.Anchored     = true
    part.Material     = Enum.Material.Brick
    part.Color        = BASEPLATE_COLOR
    part.Position     = Vector3.new(gridX, lockedY, gridZ)
    part.Transparency = 1
    part.CanCollide   = true
    part.CastShadow   = false
    part.CanTouch     = false
    part.CanQuery     = false
    part.Parent       = baseplateFolder

    TweenService:Create(part, tweenInfo, {Transparency = 0}):Play()

    baseplateGrid[key] = part
end

local function createBaseplatesAroundPlayer()
    local character = Player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if lockedY == nil then
        lockedY = getInitialY(hrp)
    end

    local pos = hrp.Position
    local currentGridX = math.floor(pos.X / BASEPLATE_SIZE) * BASEPLATE_SIZE
    local currentGridZ = math.floor(pos.Z / BASEPLATE_SIZE) * BASEPLATE_SIZE

    if currentGridX == lastGridX and currentGridZ == lastGridZ then return end
    lastGridX = currentGridX
    lastGridZ = currentGridZ

    for x = -GRID_RANGE, GRID_RANGE do
        for z = -GRID_RANGE, GRID_RANGE do
            addBaseplate(
                currentGridX + x * BASEPLATE_SIZE,
                currentGridZ + z * BASEPLATE_SIZE
            )
        end
    end
end

local function onCharacterAdded(character)
    character:WaitForChild("HumanoidRootPart")
    createBaseplatesAroundPlayer()
end

Player.CharacterAdded:Connect(onCharacterAdded)
if Player.Character then
    onCharacterAdded(Player.Character)
end

local elapsed = 0
RunService.Heartbeat:Connect(function(dt)
    elapsed += dt
    if elapsed >= UPDATE_INTERVAL then
        elapsed = 0
        createBaseplatesAroundPlayer()
    end
end)
